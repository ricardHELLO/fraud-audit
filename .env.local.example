# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase direct-Postgres (only for scripts/run-schema.js)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-database-password

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs
STRIPE_PRICE_5_CREDITS=price_...
STRIPE_PRICE_15_CREDITS=price_...
STRIPE_PRICE_50_CREDITS=price_...

# Inngest
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Anthropic (AI insights — degradación elegante si falta)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (email — degradación elegante si falta)
RESEND_API_KEY=re_...

# Upstash Redis (rate limiting — degradación elegante si falta; ver ADR-003)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Sentry (errores — degradación elegante si falta; ver ADR-008)
SENTRY_DSN=https://...@sentry.io/...
# Nivel de log (debug|info|warn|error). Default "info" en prod, "debug" en dev.
LOG_LEVEL=info

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (OBS-01) — opcional. Sin estas vars el SDK no-opera (no envía nada).
# Ver docs en instrumentation.ts / sentry.server.config.ts.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Muestreo de performance (errores se envían SIEMPRE). 0.1 = 10%.
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Para upload de source maps en build (opcional, mejora stack traces).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
